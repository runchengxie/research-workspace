{
  "submodules": {
    "market-data-platform": {
      "path": "market-data-platform",
      "profiles": {
        "smoke": [
          ["uv", "run", "--extra", "dev", "marketdata", "--help"]
        ],
        "lint": [
          ["uv", "run", "--extra", "dev", "ruff", "check", "."],
          ["uv", "run", "--extra", "dev", "ruff", "format", "--check", "."],
          ["uv", "run", "--extra", "dev", "python", "scripts/dev/architecture_governance.py", "--check"]
        ],
        "test": [
          ["uv", "run", "--extra", "dev", "pytest"]
        ],
        "type": [
          ["uv", "run", "--extra", "dev", "basedpyright"]
        ],
        "full": ["@smoke", "@lint", "@test", "@type"]
      }
    },
    "alpha-research": {
      "path": "alpha-research",
      "profiles": {
        "smoke": [
          ["uv", "run", "--extra", "dev", "python", "-c", "import sys; sys.path[:0] = ['../cross-sectional-trees/src', '../portfolio-backtester/src', 'src']; import cstree.alpha.cpcv; import cstree.alpha.signal_artifact"]
        ],
        "lint": [
          ["uv", "run", "--extra", "dev", "ruff", "check", "src"],
          ["uv", "run", "--extra", "dev", "ruff", "format", "--check", "src"]
        ],
        "test": [
          ["uv", "run", "--extra", "dev", "python", "-c", "import sys; sys.path[:0] = ['../cross-sectional-trees/src', '../portfolio-backtester/src', 'src']; import cstree.alpha.overfitting_diagnostics; import cstree.alpha.pbo"]
        ],
        "type": [
          ["uv", "run", "--extra", "dev", "basedpyright"]
        ],
        "full": ["@smoke", "@lint", "@test", "@type"]
      }
    },
    "portfolio-backtester": {
      "path": "portfolio-backtester",
      "profiles": {
        "smoke": [
          ["uv", "run", "--extra", "dev", "python", "-c", "import sys; sys.path[:0] = ['../cross-sectional-trees/src', '../alpha-research/src', 'src']; import cstree.backtesting.engine; import cstree.backtesting.metrics"]
        ],
        "lint": [
          ["uv", "run", "--extra", "dev", "ruff", "check", "src"],
          ["uv", "run", "--extra", "dev", "ruff", "format", "--check", "src"]
        ],
        "test": [
          ["uv", "run", "--extra", "dev", "python", "-c", "import sys; sys.path[:0] = ['../cross-sectional-trees/src', '../alpha-research/src', 'src']; import cstree.backtesting.execution_sim; import cstree.backtesting.reporting"]
        ],
        "type": [
          ["uv", "run", "--extra", "dev", "basedpyright"]
        ],
        "full": ["@smoke", "@lint", "@test", "@type"]
      }
    },
    "cross-sectional-trees": {
      "path": "cross-sectional-trees",
      "profiles": {
        "smoke": [
          ["uv", "run", "--extra", "dev", "cstree", "--help"]
        ],
        "lint": [
          ["scripts/dev/run_tests.sh", "lint"],
          ["scripts/dev/run_tests.sh", "format-all"],
          ["scripts/dev/run_tests.sh", "maintainability"]
        ],
        "test": [
          ["uv", "run", "--extra", "dev", "pytest"]
        ],
        "type": [
          ["uv", "run", "--extra", "dev", "basedpyright"]
        ],
        "full": ["@smoke", "@lint", "@test", "@type"]
      }
    },
    "quant-execution-engine": {
      "path": "quant-execution-engine",
      "profiles": {
        "smoke": [
          ["uv", "run", "--group", "dev", "--extra", "cli", "qexec", "--help"]
        ],
        "lint": [
          ["uv", "run", "--group", "dev", "ruff", "check", "."],
          ["uv", "run", "--group", "dev", "ruff", "format", "--check", "."]
        ],
        "test": [
          ["uv", "run", "--group", "dev", "pytest"]
        ],
        "type": [
          ["uv", "run", "--group", "dev", "python", "-m", "pyright"]
        ],
        "mypy_advisory": [
          ["uv", "run", "--group", "dev", "mypy", "src"]
        ],
        "full": ["@smoke", "@lint", "@test", "@type"]
      }
    }
  }
}

{
  "submodules": {
    "market-data-platform": {
      "path": "market-data-platform",
      "profiles": {
        "smoke": [
          ["uv", "run", "--extra", "dev", "marketdata", "--help"]
        ],
        "lint": [
          ["uv", "run", "--extra", "dev", "ruff", "check", "."],
          ["uv", "run", "--extra", "dev", "ruff", "format", "--check", "."],
          ["uv", "run", "--extra", "dev", "python", "scripts/dev/architecture_governance.py", "--check"]
        ],
        "test": [
          ["uv", "run", "--extra", "dev", "python", "-m", "pytest"]
        ],
        "type": [
          ["uv", "run", "--extra", "dev", "ty", "check"]
        ],
        "release_typecheck": [
          ["uv", "run", "--extra", "dev", "basedpyright"]
        ],
        "full": ["@smoke", "@lint", "@type", "@test"]
      }
    },
    "alpha-research": {
      "path": "alpha-research",
      "profiles": {
        "smoke": [
          ["uv", "run", "--extra", "dev", "python", "-c", "import cstree.alpha.cpcv; import cstree.alpha.signal_artifact"]
        ],
        "lint": [
          ["uv", "run", "--extra", "dev", "ruff", "check", "."],
          ["uv", "run", "--extra", "dev", "ruff", "format", "--check", "."]
        ],
        "test": [
          ["uv", "run", "--extra", "dev", "python", "-m", "pytest"]
        ],
        "type": [
          ["uv", "run", "--extra", "dev", "ty", "check"]
        ],
        "release_typecheck": [
          ["uv", "run", "--extra", "dev", "basedpyright"]
        ],
        "full": ["@smoke", "@lint", "@type", "@test"]
      }
    },
    "portfolio-backtester": {
      "path": "portfolio-backtester",
      "profiles": {
        "smoke": [
          ["uv", "run", "--extra", "dev", "python", "-c", "import cstree.backtesting.engine; import cstree.backtesting.metrics"]
        ],
        "lint": [
          ["uv", "run", "--extra", "dev", "ruff", "check", "."],
          ["uv", "run", "--extra", "dev", "ruff", "format", "--check", "."]
        ],
        "test": [
          ["uv", "run", "--extra", "dev", "python", "-m", "pytest"]
        ],
        "type": [
          ["uv", "run", "--extra", "dev", "ty", "check"]
        ],
        "release_typecheck": [
          ["uv", "run", "--extra", "dev", "basedpyright"]
        ],
        "full": ["@smoke", "@lint", "@type", "@test"]
      }
    },
    "strategy-pipeline": {
      "path": "strategy-pipeline",
      "profiles": {
        "smoke": [
          ["uv", "run", "--extra", "dev", "cstree", "--help"]
        ],
        "lint": [
          ["scripts/dev/run_tests.sh", "lint"],
          ["scripts/dev/run_tests.sh", "format-all"],
          ["scripts/dev/run_tests.sh", "maintainability"]
        ],
        "test": [
          ["uv", "run", "--extra", "dev", "python", "-m", "pytest"]
        ],
        "type": [
          ["uv", "run", "--extra", "dev", "ty", "check"]
        ],
        "release_typecheck": [
          ["uv", "run", "--extra", "dev", "python", "-m", "basedpyright"]
        ],
        "full": ["@smoke", "@lint", "@type", "@test"]
      }
    },
    "quant-execution-engine": {
      "path": "quant-execution-engine",
      "profiles": {
        "smoke": [
          ["uv", "run", "--group", "dev", "--extra", "cli", "qexec", "--help"]
        ],
        "lint": [
          ["uv", "run", "--group", "dev", "ruff", "check", "."],
          ["uv", "run", "--group", "dev", "ruff", "format", "--check", "."]
        ],
        "test": [
          ["uv", "run", "--group", "dev", "python", "-m", "pytest"]
        ],
        "type": [
          ["uv", "run", "--group", "dev", "ty", "check"]
        ],
        "release_typecheck": [
          ["uv", "run", "--group", "dev", "python", "-m", "pyright"]
        ],
        "mypy_advisory": [
          ["uv", "run", "--group", "dev", "mypy", "src"]
        ],
        "full": ["@smoke", "@lint", "@type", "@test"]
      }
    }
  }
}
